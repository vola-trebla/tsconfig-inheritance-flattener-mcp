{
  "name": "tsconfig-inheritance-flattener-mcp",
  "version": "0.1.1",
  "description": "MCP server that resolves TypeScript config inheritance chains and answers what compiler options actually apply to any file",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tsconfig-inheritance-flattener-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "prepack": "chmod +x dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "prepare": "husky"
  },
  "keywords": [
    "typescript",
    "tsconfig",
    "mcp",
    "ai",
    "developer-tools"
  ],
  "author": "vola-trebla",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "**/*.{ts,mjs,json,md}": [
      "prettier --write"
    ],
    "src/**/*.ts": [
      "eslint --fix"
    ]
  }
}
